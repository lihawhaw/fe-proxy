{
  "name": "fe-proxy",
  "displayName": "FE Proxy",
  "version": "0.0.1",
  "description": "Quick proxy front-end resource files",
  "author": "lihaha <lihaha1024@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "NODE_ENV=prod plasmo build",
    "package": "plasmo package",
    "format": "prettier --write .",
    "update:pkg": "npx npm-check-updates"
  },
  "dependencies": {
    "antd": "^5.0.1",
    "jotai": "^1.10.0",
    "plasmo": "0.55.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "3.6.0",
    "@types/chrome": "0.0.202",
    "@types/node": "18.11.9",
    "@types/react": "18.0.25",
    "@types/react-dom": "18.0.9",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.19",
    "prettier": "2.7.1",
    "tailwindcss": "^3.2.4",
    "typescript": "4.9.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ],
    "permissions": [
      "storage",
      "proxy"
    ]
  }
}
